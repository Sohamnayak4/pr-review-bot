{
  "name": "pr-review-bot",
  "version": "0.0.0",
  "description": "A self-hostable, BYOK GitHub PR reviewer powered by the LLM of your choice.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsup src/index.ts --format esm --watch",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "format": "biome check --write ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@google/genai": "^1.3.0",
    "@octokit/app": "^15.1.6",
    "@octokit/rest": "^21.1.1",
    "@octokit/webhooks": "^13.6.3",
    "fastify": "^5.3.3",
    "js-yaml": "^4.1.0",
    "openai": "^5.1.1",
    "pino": "^9.7.0",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.23",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
